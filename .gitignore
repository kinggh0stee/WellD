build/
sdkconfig.old
sdkconfig.defaults.local
managed_components/

# Secure boot — private signing key must never be committed
secure_boot_signing_key.pem

# KiCad GUI artifacts
*.kicad_prl
~*.lck
hardware/pcb/.history/
hardware/pcb/welld_bom.csv

# KiCad export artifacts (generate manually from KiCad)
hardware/pcb/gerbers/
hardware/pcb/*.bak
hardware/pcb/*.zip

# PCBWay manufacturing exports
hardware/pcb/pcbway_*.csv
hardware/pcb/pcbway_*.md

# Downloaded KiCad libraries
hardware/pcb/kicad-libs/

# On-device test build artifacts
test/*/sdkconfig
test/sensor/dependencies.lock

# IDE / local tooling
.vscode/
.idea/
.opencode/
*.swp
*.orig

# Claude Code internal state — track agents/ and commands/, ignore everything else
.claude/*
!.claude/agents/
!.claude/commands/
