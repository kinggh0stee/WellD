CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Two 1.5 MB OTA slots require at least 4 MB flash.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Zigbee stack — required for esp-zigbee-lib to register correctly in CMake.
# ZED = Zigbee End Device (battery-powered, deep-sleeping well monitor).
CONFIG_ZB_ENABLED=y
CONFIG_ZB_ZED=y
# Enable 1.x backward-compat layer in esp-zigbee-lib 2.0.x so that all
# esp_zb_* APIs that did not change continue to compile and link.
CONFIG_ZB_SDK_1xx=y

# Watchdog — reboot if a task (e.g. Zigbee stack callback) hangs.
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

# Brownout detection — log reset reason when battery sags under TX load.
CONFIG_ESP_BROWNOUT_DET=y

# Secure Boot V2 — ECDSA-P256 app signing.
# The bootloader rejects any image whose signature does not verify against the
# public key digest burned into eFuse. Once eFuses are burned this is permanent.
#
# CI builds are UNSIGNED (private key never leaves your machine).
# Sign and flash locally:
#   1. Build:  idf.py build
#   2. Sign:   espsecure sign-data --version 2 --keyfile secure_boot_signing_key.pem \
#                --output build/welld-signed.bin build/welld.bin
#   3. Flash:  idf.py -p /dev/ttyUSB0 flash   (uses the signed binary automatically
#              when CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y in local config)
#
# Key management:
#   Generate once:  espsecure generate-signing-key --version 2 --scheme ecdsa256 secure_boot_signing_key.pem
#   secure_boot_signing_key.pem is gitignored — never commit or upload it.
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_SIGNED_APPS_ECDSA_V2_SCHEME=y
# BUILD_SIGNED_BINARIES is intentionally off in shared defaults — CI builds
# unsigned; enable in sdkconfig.defaults.local on the machine that holds the key.
# CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y
# CONFIG_SECURE_BOOT_SIGNING_KEY="secure_boot_signing_key.pem"

# Secure boot bootloader is ~44 KB; default partition table offset (0x8000)
# is too small. Push to 0x10000 (64 KB) to give the bootloader headroom.
CONFIG_PARTITION_TABLE_OFFSET=0x10000
